generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model TextEntry {
  id               Int                @id @default(autoincrement())
  content          String
  createdAt        DateTime           @default(now())
  audioGenerations AudioGeneration[]
  audioAnalysis    AudioTextAnalysis?
}

model AudioGeneration {
  id          Int       @id @default(autoincrement())
  textEntryId Int
  voiceKey    String
  referenceId String
  filePath    String
  createdAt   DateTime  @default(now())
  textEntry   TextEntry @relation(fields: [textEntryId], references: [id], onDelete: Cascade)

  @@unique([textEntryId, voiceKey])
}

model AudioTextAnalysis {
  id             Int       @id @default(autoincrement())
  textEntryId    Int       @unique
  languageCode   String
  languageName   String
  charactersJson String
  fishAudioText  String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  textEntry      TextEntry @relation(fields: [textEntryId], references: [id], onDelete: Cascade)
}

model FishVoiceModel {
  referenceId   String   @id
  title         String
  description   String   @default("")
  tagsJson      String   @default("[]")
  languagesJson String   @default("[]")
  state         String
  visibility    String
  taskCount     Int      @default(0)
  cachedAt      DateTime @default(now())
}

model FishVoiceSync {
  languageCode String   @id
  refreshedAt  DateTime
}
